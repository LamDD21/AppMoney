<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="16dp"
    android:layout_marginBottom="10dp"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:id="@+id/icon_bg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_icon_food"
        android:gravity="center"
        android:layout_marginEnd="14dp">
        <TextView
            android:id="@+id/tv_txn_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🍔"
            android:textSize="22sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tv_txn_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhà hàng Highland"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:id="@+id/tv_txn_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hôm nay, 12:30"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_txn_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="-350.000đ"
        android:textColor="@color/danger"
        android:textSize="15sp"
        android:textStyle="bold"/>
</LinearLayout>