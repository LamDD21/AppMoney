<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ngân sách"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold"/>
        <Button
            android:id="@+id/btn_add_budget"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:background="@drawable/bg_btn_primary"
            android:text="+ Thêm"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingBottom="90dp">

            <!-- TOTAL BUDGET CARD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp"
                android:layout_marginBottom="20dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng ngân sách tháng"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp"/>
                    <TextView
                        android:id="@+id/tv_total_budget"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="30.000.000đ"
                        android:textColor="@color/text_primary"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰"
                    android:textSize="44sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theo danh mục"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="14dp"/>

            <!-- BUDGET ITEMS -->
            <include layout="@layout/item_budget" android:id="@+id/budget_food"/>
            <include layout="@layout/item_budget" android:id="@+id/budget_transport"/>
            <include layout="@layout/item_budget" android:id="@+id/budget_entertainment"/>
            <include layout="@layout/item_budget" android:id="@+id/budget_housing"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>